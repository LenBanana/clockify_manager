{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clockify Overtime Tracker",
  "version": "1.0.0",
  "identifier": "com.clockify-overtime-tracker.app",
  "build": {
    "frontendDist": "../dist/clockify_manager/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Clockify Overtime Tracker",
        "width": 1600,
        "height": 1000,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "startMenuFolder": "Clockify Overtime Tracker"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "publisher": "Your Company Name",
    "copyright": "Copyright (C) 2025",
    "category": "Productivity",
    "shortDescription": "Track overtime hours from Clockify with German labor compliance",
    "longDescription": "A desktop application for tracking overtime hours using Clockify time entries, with German holiday support and local data storage."
  }
}
